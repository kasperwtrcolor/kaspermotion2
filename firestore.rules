rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "PhilipSimmons67@gmail.com" && request.auth.token.email_verified == true);
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      // Allow creation: user can only create their own doc
      allow create: if isOwner(userId);

      // Allow update: user can only update their own doc
      // Credits can only be decremented or set by the owner (no self-inflation)
      allow update: if isOwner(userId) && (
        // Allow credit updates: new credits must be <= existing credits OR it's a daily reward
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['credits', 'lastRewardDate']))
        ||
        // Allow full profile updates
        request.resource.data.keys().hasAll(['uid', 'email', 'createdAt'])
      );
    }

    match /trailers/{trailerId} {
      allow read: if isDocOwner() || isAdmin() || 
        (resource.data.isPublic == true);
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update: if isDocOwner() && 
        request.resource.data.userId == resource.data.userId;
      allow delete: if isDocOwner();
    }

    match /assets/{assetId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update: if isDocOwner() && 
        request.resource.data.userId == resource.data.userId;
      allow delete: if isDocOwner();
    }
  }
}
