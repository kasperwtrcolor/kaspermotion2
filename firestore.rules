rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((request.auth.token.email == "PhilipSimmons67@gmail.com" || request.auth.token.email == "philipsimmons67@gmail.com") && request.auth.token.email_verified == true);
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      // Allow creation: user can only create their own doc
      allow create: if isOwner(userId);

      // Allow update: user can only update their own doc
      // Enforce security: client-side balance can only be DECREMENTED, 
      // unless it's a daily reward increment (lastRewardDate changed).
      allow update: if isAdmin() || (isOwner(userId) && (
        // 1. Service Usage: User is spending credits (new balance < current balance)
        (request.resource.data.credits < resource.data.credits && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['credits']))
        ||
        // 2. Daily Rewards: Balancing allowed ONLY when lastRewardDate also changes
        (request.resource.data.lastRewardDate != resource.data.lastRewardDate && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['credits', 'lastRewardDate']))
        ||
        // 3. Full metadata sync (on login)
        (request.resource.data.keys().hasAll(['uid', 'email', 'createdAt']))
      ));
    }

    match /trailers/{trailerId} {
      allow read: if isDocOwner() || isAdmin() || 
        (resource.data.isPublic == true);
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update: if isDocOwner() && 
        request.resource.data.userId == resource.data.userId;
      allow delete: if isDocOwner();
    }

    match /assets/{assetId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update: if isDocOwner() && 
        request.resource.data.userId == resource.data.userId;
      allow delete: if isDocOwner();
    }

    match /videos/{videoId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update: if isDocOwner() && 
        request.resource.data.userId == resource.data.userId;
      allow delete: if isDocOwner();
    }
  }
}
